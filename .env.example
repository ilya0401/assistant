# ── Claude API (required for speech parsing) ──────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here

# ── Jira (not used yet, reserved for next iteration) ──────────────────────────
JIRA_API_TOKEN=your_jira_token_here
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your@email.com

# ── Whisper model size ─────────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large-v2
# base = ~150MB, good balance of speed and accuracy for Russian
WHISPER_MODEL=base

# ── OS / platform ─────────────────────────────────────────────────────────────
# macos  → use docker-compose.yml
# linux  → use docker-compose.linux.yml
OS_TYPE=macos

# ── Data directory inside container ───────────────────────────────────────────
DATA_DIR=/data
