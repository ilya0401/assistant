# ── Claude API (required for speech parsing) ──────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here

# ── Jira ──────────────────────────────────────────────────────────────────────
# Токен можно задать двумя способами (JIRA_TOKEN_FILE имеет приоритет):
#   JIRA_TOKEN_FILE — путь до файла с токеном (рекомендуется для сервера)
#   JIRA_API_TOKEN  — токен напрямую в переменной
JIRA_TOKEN_FILE=/home/user/vinnie-assistant/myfile.txt
JIRA_API_TOKEN=
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your@email.com

# ── Whisper model size ─────────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large-v2
# base = ~150MB, good balance of speed and accuracy for Russian
WHISPER_MODEL=base

# ── OS / platform ─────────────────────────────────────────────────────────────
# macos  → use docker-compose.yml
# linux  → use docker-compose.linux.yml
OS_TYPE=macos

# ── Data directory inside container ───────────────────────────────────────────
DATA_DIR=/data

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=vinnie
POSTGRES_USER=vinnie
POSTGRES_PASSWORD=change_me
